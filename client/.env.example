# Frontend API target
REACT_APP_API_URL=http://localhost:3001

# Google OAuth client id (safe to expose in frontend config)
REACT_APP_GOOGLE_CLIENT_ID=

# Optional: force BrowserRouter in production if your host rewrites all paths to index.html
# Default behavior is HashRouter in production for safer deep-link refresh support.
REACT_APP_FORCE_BROWSER_ROUTER=false
